# ── Database ─────────────────────────────────────────────────────────────────
POSTGRES_URL=postgresql+asyncpg://user:password@localhost:5432/reviewscope

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Backend adapters ─────────────────────────────────────────────────────────
CORPUS_BACKEND=local           # local | dats
VECTOR_BACKEND=pgvector        # pgvector | qdrant | weaviate
EMBEDDER_BACKEND=sentence_transformers  # sentence_transformers | openai
ANNOTATION_BACKEND=local       # local | dats
AUTH_BACKEND=internal          # internal | dats

# ── LLM ──────────────────────────────────────────────────────────────────────
LLM_BASE_URL=http://localhost:11434    # Ollama (local dev)
LLM_MODEL=llama3.1                     # model name served by vLLM / Ollama

# ── External platform (sidecar mode only) ────────────────────────────────────
DATS_URL=
DATS_API_KEY=

# ── Auth ─────────────────────────────────────────────────────────────────────
SECRET_KEY=changeme
